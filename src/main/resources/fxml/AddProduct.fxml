<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="560.0" prefWidth="500.0"
      style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.closurecafepos.AddProductController">
    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>

    <Label fx:id="titleLabel" text="Add Product" textFill="#4a2e1a">
        <font><Font name="Georgia Bold" size="22.0" /></font>
        <VBox.margin><Insets bottom="20.0" /></VBox.margin>
    </Label>

    <VBox alignment="CENTER" prefHeight="130.0" prefWidth="420.0"
          style="-fx-background-color: #F5EFE8; -fx-background-radius: 12;
                 -fx-border-color: #DED0BF; -fx-border-radius: 12;
                 -fx-border-style: dashed; -fx-cursor: hand;"
          onMouseClicked="#handlePickImage">
        <VBox.margin><Insets bottom="16.0" /></VBox.margin>
        <ImageView fx:id="productImageView"
                   fitHeight="110.0" fitWidth="200.0"
                   preserveRatio="true" />
        <Label fx:id="imageLabel" text="Click to upload image" textFill="#997359">
            <font><Font name="Arial" size="12.0" /></font>
        </Label>
    </VBox>

    <HBox spacing="16.0">
        <VBox.margin><Insets bottom="14.0" /></VBox.margin>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="PRODUCT NAME" textFill="#a6793b">
                <font><Font name="Arial Bold" size="10.0" /></font>
            </Label>
            <TextField fx:id="nameField" promptText="Product name" prefHeight="40.0"
                       style="-fx-background-color: #F5EFE8; -fx-background-radius: 10;
                              -fx-border-color: #DED0BF; -fx-border-radius: 10;
                              -fx-padding: 0 10 0 10; -fx-font-size: 13px;" />
        </VBox>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="CATEGORY" textFill="#a6793b">
                <font><Font name="Arial Bold" size="10.0" /></font>
            </Label>
            <ComboBox fx:id="categoryComboBox" prefHeight="40.0" prefWidth="180.0"
                      style="-fx-background-color: #F5EFE8; -fx-background-radius: 10;
                             -fx-border-color: #DED0BF; -fx-border-radius: 10;
                             -fx-font-size: 13px;" />
        </VBox>
    </HBox>

    <HBox spacing="16.0">
        <VBox.margin><Insets bottom="14.0" /></VBox.margin>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="PRICE (₱)" textFill="#a6793b">
                <font><Font name="Arial Bold" size="10.0" /></font>
            </Label>
            <TextField fx:id="priceField" promptText="0.00" prefHeight="40.0"
                       style="-fx-background-color: #F5EFE8; -fx-background-radius: 10;
                              -fx-border-color: #DED0BF; -fx-border-radius: 10;
                              -fx-padding: 0 10 0 10; -fx-font-size: 13px;" />
        </VBox>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="AVAILABILITY" textFill="#a6793b">
                <font><Font name="Arial Bold" size="10.0" /></font>
            </Label>
            <ComboBox fx:id="availabilityComboBox" prefHeight="40.0" prefWidth="180.0"
                      style="-fx-background-color: #F5EFE8; -fx-background-radius: 10;
                             -fx-border-color: #DED0BF; -fx-border-radius: 10;
                             -fx-font-size: 13px;" />
        </VBox>
    </HBox>

    <VBox spacing="5.0">
        <VBox.margin><Insets bottom="20.0" /></VBox.margin>
        <Label text="DESCRIPTION" textFill="#a6793b">
            <font><Font name="Arial Bold" size="10.0" /></font>
        </Label>
        <TextArea fx:id="descriptionField"
                  promptText="Product description..."
                  prefHeight="70.0" prefWidth="420.0"
                  wrapText="true"
                  style="-fx-background-color: #F5EFE8; -fx-background-radius: 10;
                         -fx-border-color: #DED0BF; -fx-border-radius: 10;
                         -fx-font-size: 13px;"></TextArea>
    </VBox>

    <HBox alignment="CENTER" spacing="14.0">
        <Button mnemonicParsing="false" onAction="#handleCancel"
                prefHeight="42.0" prefWidth="110.0"
                text="Cancel" textFill="#6b4c33"
                style="-fx-background-color: white; -fx-border-color: #DED0BF;
                       -fx-border-radius: 10; -fx-background-radius: 10;">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>
        <Button mnemonicParsing="false" onAction="#handleSave"
                prefHeight="42.0" prefWidth="150.0"
                text="Save Product" textFill="WHITE"
                style="-fx-background-color: #7A4A2A; -fx-border-radius: 10;
                       -fx-background-radius: 10;">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>
    </HBox>
</VBox>