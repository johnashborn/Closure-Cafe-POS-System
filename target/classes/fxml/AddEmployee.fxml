<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="380.0" prefWidth="480.0"
      style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.closurecafepos.AddEmployeeController">
    <padding><Insets bottom="30.0" left="50.0" right="50.0" top="30.0" /></padding>

    <!-- Title -->
    <Label text="Add Employee" textFill="#4a2e1a">
        <font><Font name="Georgia Bold" size="22.0" /></font>
        <VBox.margin><Insets bottom="24.0" /></VBox.margin>
    </Label>

    <!-- Username -->
    <VBox spacing="5.0">
        <VBox.margin><Insets bottom="14.0" /></VBox.margin>
        <Label text="USERNAME" textFill="#a6793b">
            <font><Font name="Arial Bold" size="10.0" /></font>
        </Label>
        <TextField fx:id="usernameField"
                   promptText="Username"
                   prefHeight="42.0" prefWidth="380.0"
                   style="-fx-background-color: #F5EFE8; -fx-background-radius: 10;
                          -fx-border-color: #DED0BF; -fx-border-radius: 10;
                          -fx-padding: 0 10 0 10; -fx-font-size: 13px;" />
    </VBox>

    <!-- PIN + Role Row -->
    <HBox spacing="16.0">
        <VBox.margin><Insets bottom="28.0" /></VBox.margin>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="PIN" textFill="#a6793b">
                <font><Font name="Arial Bold" size="10.0" /></font>
            </Label>
            <PasswordField fx:id="pinField"
                           promptText="PIN"
                           prefHeight="42.0"
                           style="-fx-background-color: #F5EFE8; -fx-background-radius: 10;
                                  -fx-border-color: #DED0BF; -fx-border-radius: 10;
                                  -fx-padding: 0 10 0 10; -fx-font-size: 13px;" />
        </VBox>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="ROLE" textFill="#a6793b">
                <font><Font name="Arial Bold" size="10.0" /></font>
            </Label>
            <ComboBox fx:id="roleComboBox"
                      prefHeight="42.0" prefWidth="180.0"
                      style="-fx-background-color: #F5EFE8; -fx-background-radius: 10;
                             -fx-border-color: #DED0BF; -fx-border-radius: 10;
                             -fx-font-size: 13px;" />
        </VBox>
    </HBox>

    <!-- Buttons -->
    <HBox alignment="CENTER" spacing="14.0">
        <Button mnemonicParsing="false" onAction="#handleCancel"
                prefHeight="42.0" prefWidth="110.0"
                text="Cancel" textFill="#6b4c33"
                style="-fx-background-color: white; -fx-border-color: #DED0BF;
                       -fx-border-radius: 10; -fx-background-radius: 10;">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>
        <Button mnemonicParsing="false" onAction="#handleSave"
                prefHeight="42.0" prefWidth="150.0"
                text="Save Employee" textFill="WHITE"
                style="-fx-background-color: #7A4A2A; -fx-border-radius: 10;
                       -fx-background-radius: 10;">
            <font><Font name="System Bold" size="13.0" /></font>
        </Button>
    </HBox>
</VBox>